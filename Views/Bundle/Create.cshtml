@model DataBundleSystem.Models.Bundle

@{
    ViewData["Title"] = "Add New Bundle";
}

<h2>Add New Bundle</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label>Bundle Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g. 1GB Daily Bundle" />
    </div>
    <div class="mb-3">
        <label>Description</label>
        <input asp-for="Description" class="form-control" placeholder="e.g. 1GB valid for 1 day" />
    </div>
    <div class="mb-3">
        <label>Data Size</label>
        <input asp-for="DataSize" class="form-control" placeholder="e.g. 1GB" />
    </div>
    <div class="mb-3">
        <label>Price ($)</label>
        <input asp-for="Price" class="form-control" placeholder="e.g. 1.99" />
    </div>
    <div class="mb-3">
        <label>Validity (Days)</label>
        <input asp-for="ValidityDays" class="form-control" placeholder="e.g. 7" />
    </div>
    <div class="mb-3">
        <label>Available to customers?</label>
        <input asp-for="IsAvailable" type="checkbox" />
    </div>
    <button type="submit" class="btn btn-primary">Save Bundle</button>
    <a asp-action="Manage" class="btn btn-secondary">Cancel</a>
</form>